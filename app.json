{
  "expo": {
    "name": "맛담",
    "slug": "seoul-restaurant-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "matdam",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matdam.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF7A45"
      },
      "package": "com.matdam.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF7A45"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
