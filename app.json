{
  "expo": {
    "name": "맛담",
    "slug": "seoul-restaurant-list",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seoul-restaurant-list",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.seoulrestaurantlist"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FF7A45"
      },
      "package": "com.example.seoulrestaurantlist"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
